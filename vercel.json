{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/videos",
      "dest": "server.ts"
    },
    {
      "src": "/shorts",
      "dest": "server.ts"
    },
    {
      "src": "/webConfig",
      "dest": "server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}